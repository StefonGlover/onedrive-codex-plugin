ONEDRIVE_CLIENT_ID="00000000-0000-0000-0000-000000000000"
ONEDRIVE_TENANT="common"
ONEDRIVE_SCOPES="offline_access User.Read Files.ReadWrite"
# Optional for live deleted-item restore on personal OneDrive:
# ONEDRIVE_SCOPES="offline_access User.Read Files.ReadWrite Files.ReadWrite.All"
ONEDRIVE_KEYCHAIN_SERVICE="Codex OneDrive"
ONEDRIVE_STORAGE_ROOT="$HOME/.codex/onedrive-plugin"
ONEDRIVE_CACHE_ROOT="$HOME/.codex/onedrive-plugin/cache"
ONEDRIVE_CACHE_TTL_SECONDS="900"
ONEDRIVE_MAX_SCAN_DEPTH="25"
ONEDRIVE_MAX_INDEXED_FILE_SIZE="524288"
ONEDRIVE_INDEX_EXTENSIONS=".txt,.md,.csv,.json,.jsonl,.xml,.yaml,.yml,.html,.css,.js,.mjs,.ts,.tsx,.py,.sql,.log"
ONEDRIVE_CONCURRENCY_LIMIT="2"
ONEDRIVE_DELTA_SYNC_ENABLED="true"
ONEDRIVE_CONTENT_INDEX_ENABLED="true"
ONEDRIVE_INDEX_OFFICE_EXPORT="false"
