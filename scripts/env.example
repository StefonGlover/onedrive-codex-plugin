ONEDRIVE_CLIENT_ID="00000000-0000-0000-0000-000000000000"
ONEDRIVE_TENANT="common"
ONEDRIVE_SCOPES="offline_access User.Read Files.ReadWrite"
# Optional for live deleted-item restore on personal OneDrive:
# ONEDRIVE_SCOPES="offline_access User.Read Files.ReadWrite Files.ReadWrite.All"
ONEDRIVE_KEYCHAIN_SERVICE="Codex OneDrive"
ONEDRIVE_STORAGE_ROOT="$HOME/.codex/onedrive-plugin"
ONEDRIVE_CACHE_ROOT="$HOME/.codex/onedrive-plugin/cache"
ONEDRIVE_CACHE_TTL_SECONDS="900"
ONEDRIVE_MAX_SCAN_DEPTH="25"
ONEDRIVE_MAX_INDEXED_FILE_SIZE="524288"
ONEDRIVE_INDEX_EXTENSIONS=".txt,.md,.csv,.json,.jsonl,.xml,.yaml,.yml,.html,.css,.js,.mjs,.ts,.tsx,.py,.sql,.log"
ONEDRIVE_CONCURRENCY_LIMIT="2"
ONEDRIVE_DELTA_SYNC_ENABLED="true"
ONEDRIVE_CONTENT_INDEX_ENABLED="true"
ONEDRIVE_INDEX_OFFICE_EXPORT="false"

# Optional ChatGPT Work / delegated MCP OAuth mode. The API registration is
# the confidential middle tier that validates ChatGPT's Entra token and uses
# the on-behalf-of flow for Microsoft Graph. Keep its secret in a private file.
ONEDRIVE_MCP_AUTH_MODE="noauth"
# ONEDRIVE_MCP_OAUTH_TENANT="consumers"
# ONEDRIVE_MCP_OAUTH_API_CLIENT_ID="00000000-0000-0000-0000-000000000000"
# ONEDRIVE_MCP_OAUTH_API_CLIENT_SECRET_FILE="/run/onedrive-runtime/oauth-api-client.secret"
# ONEDRIVE_MCP_RESOURCE="api://00000000-0000-0000-0000-000000000000"
# ONEDRIVE_MCP_OAUTH_API_SCOPE="api://00000000-0000-0000-0000-000000000000/access_as_user"
# ONEDRIVE_MCP_OAUTH_SCOPE_CLAIM="access_as_user"
# ONEDRIVE_MCP_OAUTH_AUDIENCE="00000000-0000-0000-0000-000000000000"
# ONEDRIVE_MCP_OAUTH_AUTHORITY="https://login.microsoftonline.com/consumers/v2.0"
# ONEDRIVE_MCP_OAUTH_GRAPH_SCOPES="https://graph.microsoft.com/.default"
# ONEDRIVE_MCP_PUBLIC_BASE_URL="https://your-public-mcp-origin.example"
